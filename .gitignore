# ==============================================
#   SmartSchool OS — .gitignore
#   React + Vite + Tailwind CSS + Windows
# ==============================================


# ── Dependencies ──────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz


# ── Build Output ──────────────────────────────
dist/
dist-ssr/
build/
out/


# ── Environment & Secrets ─────────────────────
# NEVER commit API keys, secrets, or credentials
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
*.env


# ── Vite Cache ────────────────────────────────
.vite/
vite.config.js.timestamp-*


# ── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# ── Runtime / Temp Files ──────────────────────
*.local
*.tmp
*.temp
.cache/
.parcel-cache/


# ── OS — Windows ──────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk


# ── OS — macOS ────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes


# ── OS — Linux ────────────────────────────────
*~


# ── IDEs & Editors ────────────────────────────
# VS Code — keep only your shared workspace settings
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# JetBrains (WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Emacs / Sublime swap files
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
[._]*.s[a-v][a-z]
[._]*.s[w][a-z]
Session.vim
.netrwhist


# ── Testing ───────────────────────────────────
coverage/
.nyc_output/
*.lcov


# ── Miscellaneous ─────────────────────────────
*.tgz
*.zip
*.tar.gz
.eslintcache
.stylelintcache
.node_repl_history
.yarn-integrity


# ── Package manager lock files ────────────────
# Commit ONE of these — whichever you use.
# If using npm  → keep package-lock.json, ignore the rest.
# If using yarn → keep yarn.lock, ignore the rest.
yarn.lock
pnpm-lock.yaml
# package-lock.json  ← uncomment this line if using yarn/pnpm
